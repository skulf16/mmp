# ── Kontaktformular / SMTP (kasserver) ─────────────────────────────
# Login = Account-ID (Postfach-Nr.), NICHT die E-Mail-Adresse
SMTP_HOST=w0xxxxxx.kasserver.com
SMTP_PORT=465
SMTP_USER=m0xxxxxx
SMTP_PASS=
SMTP_FROM="Miss Moneypenny <anfrage@chartern-in-kroatien.de>"
CONTACT_TO=anfrage@chartern-in-kroatien.de

# ── Tracking / Analytics ───────────────────────────────────────────
# Google-Tag-Manager-Web-Container-ID. Wenn gesetzt, wird GTM geladen und
# GA4/Google-Ads laufen über den Container. Leer/nicht gesetzt → GA4-Fallback.
NEXT_PUBLIC_GTM_ID=

# First-Party-Loader-Origin des serverseitigen GTM-Containers (Hetzner/Coolify).
# gtm.js / gtag/js / ns.html werden von hier ausgeliefert → umgeht Ad-Blocker.
# Leer → Auslieferung über Google-CDN (www.googletagmanager.com).
NEXT_PUBLIC_GTM_LOADER_URL=https://sst.chartern-in-kroatien.de

# GA4-Mess-ID für den Direkt-Fallback, solange GTM nicht konfiguriert ist.
# Optional – in lib/analytics.ts ist die Bestands-Property als Default hinterlegt.
NEXT_PUBLIC_GA_ID=G-D5PXZXJWTC
